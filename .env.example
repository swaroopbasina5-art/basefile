# Google Drive folder ID (from the folder URL)
# e.g., https://drive.google.com/drive/folders/FOLDER_ID_HERE
DRIVE_FOLDER_ID=your_drive_folder_id_here

# Output Google Sheet ID (create a blank Google Sheet and paste its ID)
# e.g., https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
OUTPUT_SHEET_ID=your_google_sheet_id_here

# Path to your Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json
