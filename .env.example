# Retool Credentials (copy this to .env and fill in)
RETOOL_EMAIL=your-email@example.com
RETOOL_PASSWORD=your-password
RETOOL_BASE_URL=https://lsn.retool.com
RETOOL_PAGE_UUID=644f7cc8-a1c9-11ef-8d91-fbdebd641690
RETOOL_QUERY_NAME=get_order_details

# Sync schedule (cron expression, default: every 30 minutes)
SYNC_CRON=*/30 * * * *

# Data output directory
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
